# 智聘 · 招聘管理系统 — 环境配置模板
# 复制此文件为 .env 并填入真实值（.env 切勿提交版本库 / 切勿外泄）

# ── LLM 配置（与 base_agent/llm_config.json 对应）────────────────
# base_agent 的 LLM 模块读取 OPENAI_API_KEY / OPENROUTER_API_KEY / API_KEY / DEEPSEEK_API_KEY。
# DeepSeek 用 Bearer 鉴权，key 放 OPENAI_API_KEY 即可被所有模块识别。
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-v4-flash
LLM_API_URL=https://api.deepseek.com/v1/chat/completions
LLM_MAX_TOKENS=8192

# API Key（填你自己的，多个别名指向同一个 key）
OPENAI_API_KEY=sk-your-key-here
DEEPSEEK_API_KEY=sk-your-key-here
API_KEY=sk-your-key-here
LLM_API_KEY=sk-your-key-here

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRY_HOURS=8

# 数据库（开发用 SQLite，生产改为 postgresql://user:pass@host/db）
DATABASE_URL=sqlite:///hireinsight.db

# 文件上传
UPLOAD_FOLDER=uploads

# Celery（开发用 eager 模式，生产改为 redis://localhost:6379/0）
CELERY_BROKER_URL=memory://
CELERY_TASK_ALWAYS_EAGER=true

# Flask
FLASK_DEBUG=true
PORT=5000
