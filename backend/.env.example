# 智聘 · 招聘管理系统 — 环境配置模板
# 复制此文件为 .env 并填入真实值（.env 切勿提交版本库 / 切勿外泄）

# ── LLM 配置（与 base_agent/llm_config.json 对应）────────────────
# 主推荐字段：OPENAI_API_KEY。DeepSeek 使用 OpenAI 兼容接口，key 放这里即可。
# 为兼容旧模块，DEEPSEEK_API_KEY / API_KEY / LLM_API_KEY 可填同一个 key。
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-v4-flash
LLM_API_URL=https://api.deepseek.com/v1/chat/completions
LLM_MAX_TOKENS=8192

# API Key（填你自己的；多个别名建议指向同一个 key，避免不同模块读不到）
OPENAI_API_KEY=sk-your-key-here
DEEPSEEK_API_KEY=sk-your-key-here
API_KEY=sk-your-key-here
LLM_API_KEY=sk-your-key-here

# JWT
# 生产必须改为强随机值（>=32 字符）；生成：python3 -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-production
JWT_EXPIRY_HOURS=8

# 数据库（开发用 SQLite，生产改为 PostgreSQL；postgresql:// 会自动转为 psycopg v3 驱动）
DATABASE_URL=sqlite:///hireinsight.db

# 安全（生产/试点）
# 公开注册开关：生产保持 false，账号由 admin 创建
ALLOW_PUBLIC_REGISTRATION=false
# CORS 白名单：生产必填，逗号分隔，如 https://zhipin.内网域名
CORS_ORIGINS=
# 应用侧兜底安全头和轻量限流；Nginx 层仍建议配置 limit_req
SECURITY_HEADERS_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN=10
RATE_LIMIT_AGENT_CHAT=20
RATE_LIMIT_RESUME_UPLOAD=8

# 文件上传
UPLOAD_FOLDER=uploads

# 备份目录（配合 backend/scripts/backup_pilot_data.py）
BACKUP_DIR=../backups

# Celery（开发用 eager 模式，生产改为 redis://localhost:6379/0）
CELERY_BROKER_URL=memory://
CELERY_TASK_ALWAYS_EAGER=true

# Flask
FLASK_DEBUG=true
PORT=5000

# ── boss-cli（BOSS 直聘招聘端集成）─────────────────────────
# 开源项目 https://github.com/jackwener/boss-cli 。
# 注意：招聘端 recruiter 命令仅在 GitHub 源码版含，PyPI 包未收录，故从源码安装：
#   pip install git+https://github.com/jackwener/boss-cli.git
# boss 二进制路径覆盖（默认 shutil.which("boss") 自动探测）
# BOSS_CLI_BIN=
# 缺失时是否自动从 GitHub 安装 boss-cli（默认 true）
BOSS_CLI_AUTO_INSTALL=true

# 字段级加密密钥（Fernet，用于加密 BOSS 账号 cookies）
# 生成：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 【云部署必填】留空时开发环境会生成临时内存密钥，进程重启/扩容后旧密文将无法解密，
# 已保存的 BOSS 账号 cookie 会全部失效。生产环境务必固定此值并妥善保管。
FIELD_ENCRYPTION_KEY=
