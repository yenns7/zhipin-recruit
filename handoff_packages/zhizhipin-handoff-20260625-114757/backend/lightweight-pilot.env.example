# 智聘轻量生产试点配置模板
# 用法：复制为 backend/.env 后替换所有 change-me / example 值。
# 注意：真实 backend/.env 不要提交到 git。

LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-v4-flash
LLM_API_URL=https://api.deepseek.com/v1/chat/completions
LLM_MAX_TOKENS=8192

# 真实候选人数据进入 AI 前，负责人需要确认隐私告知、授权和人工复核规则。
AI_RECRUITMENT_COMPLIANCE_ACK=true
CANDIDATE_PRIVACY_NOTICE_URL=https://zhipin.example.com/privacy
AI_HUMAN_REVIEW_REQUIRED=true

# DeepSeek/OpenAI 兼容 key。真实试点前先确认简历/JD/面试内容外发边界。
OPENAI_API_KEY=sk-change-me
DEEPSEEK_API_KEY=sk-change-me
API_KEY=sk-change-me
LLM_API_KEY=sk-change-me

# 必须替换为强随机值：
# python3 -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me
JWT_EXPIRY_HOURS=8

# 真实试点请使用 PostgreSQL，不要用本地 SQLite。
DATABASE_URL=postgresql://zhipin_user:change-me@127.0.0.1:5432/zhipin

# 公司内网域名或试点域名，多个域名用英文逗号分隔。
CORS_ORIGINS=https://zhipin.example.com

ALLOW_PUBLIC_REGISTRATION=false
SECURITY_HEADERS_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN=10
RATE_LIMIT_AGENT_CHAT=20
RATE_LIMIT_RESUME_UPLOAD=8

UPLOAD_FOLDER=/var/lib/zhipin/uploads
BACKUP_DIR=/var/backups/zhipin

CELERY_BROKER_URL=memory://
CELERY_TASK_ALWAYS_EAGER=true

FLASK_DEBUG=false
PORT=5000
