{
  "manifest_version": 3,
  "name": "智聘 BOSS Cookie 采集",
  "description": "一键采集 BOSS 直聘 Cookie，直接发送到智聘平台，无需手动复制粘贴",
  "version": "4.1.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "webRequest",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://*.zhipin.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
